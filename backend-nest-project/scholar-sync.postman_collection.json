      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "dave@example.com",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "Password123",
      "type": "string"
    },
    {
      "key": "createdCourseId",
      "value": "",
      "type": "string"
    },
    {
      "key": "createdUserCourseId",
      "value": "",
